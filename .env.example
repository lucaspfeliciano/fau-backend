# Porta HTTP da API NestJS.
PORT=3000

# Ambiente de execucao (development, test, production).
NODE_ENV=development

# Nivel de log da aplicacao (debug, info, warn, error).
LOG_LEVEL=info

# Habilita/desabilita publicacao de Swagger em /docs.
SWAGGER_ENABLED=true

# Segredo usado para assinar e validar JWT.
JWT_SECRET=replace-with-secure-secret

# Tempo de expiracao do JWT em segundos.
JWT_EXPIRES_IN_SECONDS=28800

# Custo do hash de senha para contas locais (email + senha).
PASSWORD_SALT_ROUNDS=10

# Origem(ns) permitidas para CORS (separadas por virgula). Ex.: http://localhost:5173
CORS_ORIGIN=

# Client ID do Google OAuth para validar idToken/credential no backend.
GOOGLE_CLIENT_ID=

# String de conexao principal do MongoDB.
MONGODB_URI=mongodb://bloomie:KDeDLFlJwKJRhxVL@ac-gmkce7n-shard-00-00.zr4jg1h.mongodb.net:27017,ac-gmkce7n-shard-00-01.zr4jg1h.mongodb.net:27017,ac-gmkce7n-shard-00-02.zr4jg1h.mongodb.net:27017/fau?ssl=true&authSource=admin&replicaSet=atlas-ta6z44-shard-0&retryWrites=true&w=majority&appName=bloomie

# Nome do banco MongoDB (opcional, sobrescreve o nome implicito da URI).
MONGODB_DB_NAME=fau-backend

# Webhook de envio de notificacoes para Slack.
SLACK_WEBHOOK_URL=

# Chave de API para sincronizacao com HubSpot.
HUBSPOT_API_KEY=

# Chave de API para sincronizacao com Linear.
LINEAR_API_KEY=

# Limiar minimo de confianca da classificacao no pipeline de IA.
AI_CONFIDENCE_THRESHOLD=0.65
